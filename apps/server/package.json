{
  "name": "@lobster-world/server",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pg": "vitest run tests/pg/",
    "test:all": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:migrate:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "@lobster-world/protocol": "workspace:*",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.3.3",
    "postgres": "^3.4.8",
    "tweetnacl": "^1.0.3",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.4.2",
    "@types/node": "^22.15.21",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
