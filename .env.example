# =============================================================================
# Lobster World — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env
# =============================================================================

# --- Server ---
NODE_ENV=development
PORT=3001
HOST=0.0.0.0
CORS_ORIGINS=http://localhost:5173

# --- PostgreSQL Connection ---
# Full connection URL (overrides individual PG_* vars if set)
DATABASE_URL=postgres://lobster:lobster_dev@localhost:5432/lobster_world

# Individual connection vars (used by docker-compose and as fallback)
POSTGRES_DB=lobster_world
POSTGRES_USER=lobster
POSTGRES_PASSWORD=lobster_dev
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Connection Pool ---
# Maximum number of connections in the pool (default: 10)
DB_POOL_MAX=10
# Idle connection timeout in seconds (default: 20)
DB_POOL_IDLE_TIMEOUT=20
# Connection timeout in seconds (default: 10)
DB_POOL_CONNECT_TIMEOUT=10
# Maximum lifetime of a connection in seconds (0 = unlimited, default: 0)
DB_POOL_MAX_LIFETIME=0
